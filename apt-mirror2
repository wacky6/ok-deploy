#!/bin/bash
set -e

# Constants
MIRROR_CONFIG_URL="https://raw.githubusercontent.com/wacky6/ok-deploy/refs/heads/master/apt-mirrors.list"
APT_MIRROR_2_IMAGE="ghcr.io/wacky6/apt-mirror2:pr-1"
INSTALL_DIR="/root"
CRON_WRAPPER=".apt-mirror2-cron"
WRAPPER_PATH="$INSTALL_DIR/$CRON_WRAPPER"
LOG_FILE="/var/log/apt-mirror-2-last-run"

# Resolve script directory
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# 1. Check for docker or call docker-ce script
if command -v docker >/dev/null 2>&1; then
    echo "Docker is already installed."
elif [ -f "$SCRIPT_DIR/docker-ce" ]; then
    echo "Running docker-ce script..."
    bash "$SCRIPT_DIR/docker-ce"
else
    echo "Warning: docker-ce script not found in $SCRIPT_DIR and docker is not in PATH"
fi

# 2. Write the cron script (Atomic update)
echo "Generating cron script at $WRAPPER_PATH..."
TMP_WRAPPER=$(mktemp)
cat <<EOF > "$TMP_WRAPPER"
#!/bin/bash
set -e

# 1. Exit if this cron script is running (Locking)
exec {lock_fd}< "\$0"
if ! flock -n "\$lock_fd"; then
    echo "Script is already running. Exiting."
    exit 1
fi

# 2. Pull docker image
echo "Pulling docker image: $APT_MIRROR_2_IMAGE"
docker pull "$APT_MIRROR_2_IMAGE"

# 3. Pull apt-mirrors.list
echo "Downloading mirror config..."
mkdir -p /etc/apt
curl -vSL "$MIRROR_CONFIG_URL" -o /etc/apt/mirror.list

# 4. Run the docker image
echo "Running apt-mirror2 container..."
docker run --rm \\
    -v /mirrors:/mirrors \\
    -v /var/apt-mirror2:/var/apt-mirror \\
    -v /etc/apt/mirror.list:/etc/apt/mirror.list \\
    "$APT_MIRROR_2_IMAGE"
EOF

chmod +x "$TMP_WRAPPER"
mv "$TMP_WRAPPER" "$WRAPPER_PATH"
echo "Cron script generated."

# 3. Set up crontab (System-wide cron)
CRON_FILE="/etc/cron.d/apt-mirror2"
echo "Setting up system cron at $CRON_FILE..."
cat <<EOF > "$CRON_FILE"
# Run apt-mirror2 at 5:00 AM every day
0 5 * * * root $WRAPPER_PATH > $LOG_FILE 2>&1
EOF

echo "Setup complete."
