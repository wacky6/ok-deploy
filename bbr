#!/bin/bash
#
# bbr configuration
#

# Check if bbr is available as a module or built-in
if ! modprobe tcp_bbr 2>/dev/null && ! grep -q "bbr" /proc/sys/net/ipv4/tcp_allowed_congestion_control; then
    echo "ERROR: BBR is not supported by the current kernel." >&2
    echo "This script requires a kernel with BBR support (Ubuntu 24/26)." >&2
    exit 1
fi

echo "Kernel has bbr support"

_write_sysctl() {
    LINE=$1
    FILE=/etc/sysctl.conf
    if ! grep "$LINE" $FILE > /dev/null 2>&1; then
        echo $LINE >> $FILE
    else
        echo already written: $LINE
    fi
}

_write_sysctl net.core.default_qdisc=fq
_write_sysctl net.ipv4.tcp_congestion_control=bbr
